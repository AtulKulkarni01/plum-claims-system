# Copy to .env and fill in.   ->   cp .env.example .env
#
# The system runs fully and deterministically with NO env vars set
# (all 12 eval cases pass without a key). These only enable optional
# LLM extraction of real, unstructured documents.
#
# Extraction uses a failover chain: Gemini 2.5 Flash (primary), then OpenAI
# (fallback), each with retry + exponential backoff. Set either, both, or neither.

# Google Gemini — primary extraction provider.  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI — fallback extraction provider.  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional model overrides
# CLAIMS_LLM_MODEL=gemini-2.5-flash
# CLAIMS_OPENAI_MODEL=gpt-4o-mini

# Optional failover tuning
# CLAIMS_LLM_RETRIES=2          # attempts per provider before failing over
# CLAIMS_LLM_BACKOFF=0.5        # base seconds for exponential backoff (0.5, 1, 2, …)
